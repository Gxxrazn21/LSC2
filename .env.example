# =============================================================
# .env.example - Plantilla de configuracion para el proyecto LSC
#
# COPIA este archivo como .env y ajusta valores segun tu maquina.
#   Windows PowerShell:  Copy-Item .env.example .env
#   Bash / WSL:          cp .env.example .env
#
# Todas las variables son OPCIONALES. config.py trae valores por
# defecto sensatos, el .env solo sirve para sobrescribirlos sin
# modificar el codigo.
# =============================================================

# --- Dispositivo: cpu | cuda (vacio = auto detectar GPU) ---
LSC_DEVICE=

# --- Rutas de datasets (relativas a la raiz del proyecto o absolutas) ---
LSC_DATASETS_DIR=datasets
LSC70_PATH=datasets/LSC70/LSC70ANH
LSC54_PATH=datasets/LSC-54
LSC50_PATH=datasets/LSC50

# --- Rutas de salida ---
LSC_MODELOS_DIR=modelos_guardados
LSC_RESULTADOS_DIR=resultados

# --- MediaPipe (archivos .task en la raiz del proyecto) ---
HAND_LANDMARKER_PATH=hand_landmarker.task
FACE_DETECTOR_PATH=face_detector.task

# --- Camara / reconocimiento en vivo ---
CAMERA_INDEX=0
UMBRAL_CONFIANZA=0.70
FRAMES_ESTABLES=10
COOLDOWN_TTS_SEG=1.5
TTS_RATE=160

# --- Fase 1 (CNN + LSC70) ---
FASE1_BATCH_SIZE=32
FASE1_EPOCHS=30
FASE1_LR=0.001
FASE1_IMG_SIZE=128
FASE1_VALID_SPLIT=0.2

# --- Fase 2 (LSTM + LSC-54) ---
FASE2_BATCH_SIZE=16
FASE2_EPOCHS=40
FASE2_LR=0.001
FASE2_HIDDEN_SIZE=128
FASE2_NUM_LAYERS=2
FASE2_MAX_SEQ_LEN=60
FASE2_VALID_SPLIT=0.2

# --- Fase 3 (multimodal + LSC50) ---
FASE3_BATCH_SIZE=8
FASE3_EPOCHS=30
FASE3_LR=0.0005
FASE3_MAX_FRAMES=30
FASE3_IMG_SIZE=64
FASE3_VALID_SPLIT=0.2

# --- General ---
SEED=42
PRINT_EVERY=5
